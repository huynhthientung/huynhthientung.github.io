---
const sites = [
  {
    title: 'Docs',
    description: 'Technical references, runbooks, and engineering notes',
    href: 'https://docs.huynhthientung.com',
    domain: 'docs.huynhthientung.com',
  },
  {
    title: 'Blog',
    description: 'Writing on DevOps, cloud, and software engineering',
    href: 'https://blogs.huynhthientung.com',
    domain: 'blogs.huynhthientung.com',
  },
  {
    title: 'EnglishPod',
    description: 'Curated audio resources for English listening practice',
    href: 'https://englishpod.huynhthientung.com',
    domain: 'englishpod.huynhthientung.com',
  },
];
---

<section>
  <h2 class="text-[12px] font-medium tracking-[0.18em] uppercase text-stone-400 dark:text-stone-500 mb-5">
    Explore
  </h2>

  <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
    {sites.map((site) => (
      <a
        href={site.href}
        target="_blank"
        rel="noopener noreferrer"
        class="group flex flex-col gap-2 p-5 rounded-xl border border-stone-200 dark:border-stone-800 bg-white/60 dark:bg-stone-900/40 hover:border-indigo-400/60 dark:hover:border-indigo-500/40 hover:bg-white dark:hover:bg-stone-900 hover:shadow-sm transition-all"
      >
        <div class="flex items-center justify-between">
          <span class="text-[16px] font-semibold text-stone-900 dark:text-stone-50 group-hover:text-indigo-600 dark:group-hover:text-indigo-400 transition-colors">
            {site.title}
          </span>
          <svg
            class="w-4 h-4 text-stone-300 dark:text-stone-700 group-hover:text-indigo-500 dark:group-hover:text-indigo-400 group-hover:translate-x-0.5 group-hover:-translate-y-0.5 transition-all"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path d="M7 17L17 7M9 7h8v8" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </div>
        <p class="text-[14px] text-stone-600 dark:text-stone-400 leading-[1.6]">
          {site.description}
        </p>
        <span class="text-[12px] tabular-nums text-stone-400 dark:text-stone-600 mt-auto pt-1">
          {site.domain}
        </span>
      </a>
    ))}
  </div>
</section>
