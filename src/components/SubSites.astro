---
const sites = [
  {
    title: 'Docs',
    description: 'Technical references, runbooks, and engineering notes',
    href: 'https://docs.huynhthientung.com',
    domain: 'docs.huynhthientung.com',
  },
  {
    title: 'Blog',
    description: 'Writing on DevOps, cloud infrastructure, and engineering',
    href: 'https://blogs.huynhthientung.com',
    domain: 'blogs.huynhthientung.com',
  },
  {
    title: 'EnglishPod',
    description: 'Curated audio resources for English listening practice',
    href: 'https://englishpod.huynhthientung.com',
    domain: 'englishpod.huynhthientung.com',
  },
];
---

<section>
  <h2 class="text-[11px] font-medium tracking-[0.18em] uppercase text-slate-400 dark:text-slate-500 mb-7">
    Links
  </h2>

  <ul class="border-t border-slate-100 dark:border-slate-900">
    {sites.map((site) => (
      <li class="border-b border-slate-100 dark:border-slate-900">
        <a
          href={site.href}
          target="_blank"
          rel="noopener noreferrer"
          class="group flex items-baseline justify-between gap-4 py-4"
        >
          <div class="min-w-0">
            <div class="flex items-baseline gap-3">
              <span class="text-[15px] font-semibold text-slate-900 dark:text-slate-50">
                {site.title}
              </span>
              <span class="text-[13px] tabular-nums text-slate-400 dark:text-slate-600 truncate">
                {site.domain}
              </span>
            </div>
            <p class="text-[13px] text-slate-500 dark:text-slate-500 mt-1">
              {site.description}
            </p>
          </div>
          <svg
            class="w-3.5 h-3.5 mt-1 shrink-0 text-slate-300 dark:text-slate-700 group-hover:text-slate-700 dark:group-hover:text-slate-300 group-hover:translate-x-0.5 transition-all"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path d="M9 18l6-6-6-6" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </a>
      </li>
    ))}
  </ul>
</section>
