---
---

<section>
  <h2 class="text-[12px] font-medium tracking-[0.18em] uppercase text-zinc-500 dark:text-zinc-500 mb-7">
    Certifications
  </h2>

  <div class="space-y-5">
    <div class="flex flex-wrap items-start justify-between gap-x-3 gap-y-2">
      <div class="text-[15px] flex items-center gap-2 flex-wrap">
        <span class="inline-flex items-center gap-1.5 px-2 py-0.5 rounded-md bg-amber-50 dark:bg-amber-900/15 border border-amber-200 dark:border-amber-800/50 text-amber-700 dark:text-amber-400 text-[11px] font-semibold tracking-wide uppercase">
          AWS
        </span>
        <span class="font-medium text-zinc-800 dark:text-zinc-100">
          Solutions Architect — Associate
        </span>
        <a
          href="https://cp.certmetrics.com/amazon/en/public/verify/credential/5e104e2b6dd54b33b730b3b151c18721"
          target="_blank"
          rel="noopener noreferrer"
          class="text-[13px] text-green-600 dark:text-green-400 hover:text-green-700 dark:hover:text-green-300 underline-offset-4 hover:underline transition-colors"
        >
          verify ↗
        </a>
      </div>
      <span class="text-[13px] tabular-nums text-zinc-500 dark:text-zinc-500 shrink-0">Amazon Web Services</span>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-[200px_1fr] gap-y-1 sm:gap-x-6">
      <dt class="text-[14px] font-medium text-zinc-500 dark:text-zinc-400 sm:pt-0.5">
        In progress
      </dt>
      <dd class="flex flex-wrap gap-1.5">
        {['CKA', 'AWS SAP', 'IELTS 6.0'].map((cert) => (
          <span class="inline-block px-2.5 py-0.5 rounded-md text-[12.5px] font-medium text-zinc-600 dark:text-zinc-400 bg-zinc-100 dark:bg-zinc-800 border border-zinc-200 dark:border-zinc-700/70 leading-6">
            {cert}
          </span>
        ))}
      </dd>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-[200px_1fr] gap-y-1 sm:gap-x-6">
      <dt class="text-[14px] font-medium text-zinc-500 dark:text-zinc-400 sm:pt-0.5">
        English
      </dt>
      <dd class="text-[15px] text-zinc-700 dark:text-zinc-300 leading-[1.7]">
        TOEIC — Reading &amp; Listening 690, Speaking &amp; Writing 250
      </dd>
    </div>
  </div>
</section>
