<section>
  <h2 class="text-[12px] font-medium tracking-[0.18em] uppercase text-stone-400 dark:text-stone-500 mb-7">
    Certifications
  </h2>

  <div class="space-y-5">
    <div class="flex flex-wrap items-baseline justify-between gap-x-3 gap-y-0.5">
      <div class="text-[15px]">
        <span class="font-medium text-stone-800 dark:text-stone-100">
          AWS Certified Solutions Architect — Associate
        </span>
        <a
          href="https://cp.certmetrics.com/amazon/en/public/verify/credential/5e104e2b6dd54b33b730b3b151c18721"
