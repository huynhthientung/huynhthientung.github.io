<section>
  <h2 class="text-[11px] font-medium tracking-[0.18em] uppercase text-slate-400 dark:text-slate-500 mb-7">
    Certifications
  </h2>

  <div class="space-y-5">
    <div class="flex flex-wrap items-baseline justify-between gap-x-3 gap-y-0.5">
      <div class="text-[14px]">
        <span class="font-medium text-slate-800 dark:text-slate-200">
          AWS Certified Solutions Architect — Associate
        </span>
        <a
          href="https://cp.certmetrics.com/amazon/en/public/verify/credential/5e104e2b6dd54b33b730b3b151c18721"
