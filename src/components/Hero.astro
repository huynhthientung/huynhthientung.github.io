---
const linkClass =
  'text-stone-700 dark:text-stone-300 hover:text-indigo-600 dark:hover:text-indigo-400 underline-offset-4 hover:underline transition-colors';
---

<section class="pt-14 pb-10">
  <div class="flex items-center gap-5 mb-6">
    <div
      aria-hidden="true"
      class="w-14 h-14 rounded-full bg-stone-200/80 dark:bg-stone-800/80 flex items-center justify-center text-stone-600 dark:text-stone-300 font-medium text-base select-none"
    >
      TH
    </div>
    <div>
      <h1
        class="text-[34px] sm:text-[38px] font-semibold tracking-tight text-stone-900 dark:text-stone-50 leading-[1.1]"
      >
        Huynh Thien Tung
      </h1>
      <p class="text-[17px] text-stone-600 dark:text-stone-400 mt-1">
        Cloud / DevOps Engineer
      </p>
    </div>
  </div>

  <p class="text-[15px] text-stone-600 dark:text-stone-400 leading-[1.75] max-w-[600px] mb-7">
    Building reliable, scalable infrastructure on AWS — bridging software
    engineering and cloud operations with a security-first mindset.
  </p>

  <!-- Contact: warm, inline, with thin separators -->
  <div class="flex flex-wrap items-center gap-x-3 gap-y-1.5 text-[14px] text-stone-500 dark:text-stone-500">
    <span>Ho Chi Minh City, Vietnam</span>
    <span class="text-stone-300 dark:text-stone-700" aria-hidden="true">•</span>
    <a href="mailto:huynhthientung.dev@gmail.com" class={linkClass}>
      huynhthientung.dev@gmail.com
    </a>
    <span class="text-stone-300 dark:text-stone-700" aria-hidden="true">•</span>
    <a
      href="https://www.linkedin.com/in/huynhthientung/"
      target="_blank"
      rel="noopener noreferrer"
      class={linkClass}
    >
      LinkedIn
    </a>
    <span class="text-stone-300 dark:text-stone-700" aria-hidden="true">•</span>
    <a
      href="https://github.com/huynhthientung"
      target="_blank"
      rel="noopener noreferrer"
      class={linkClass}
    >
      GitHub
    </a>
  </div>
</section>
