---
const linkClass =
  'text-zinc-700 dark:text-zinc-300 hover:text-green-600 dark:hover:text-green-400 underline-offset-4 hover:underline transition-colors';
---

<section class="pt-14 pb-10">
  <div class="flex items-center gap-5 mb-6">
    <div
      aria-hidden="true"
      class="w-14 h-14 rounded-full bg-zinc-200/80 dark:bg-zinc-800/80 flex items-center justify-center text-zinc-600 dark:text-zinc-300 font-medium text-base select-none"
    >
      TH
    </div>
    <div>
      <h1
        class="text-[34px] sm:text-[38px] font-semibold tracking-tight text-zinc-900 dark:text-zinc-50 leading-[1.1]"
      >
        Huynh Thien Tung
      </h1>
      <p class="text-[17px] text-zinc-600 dark:text-zinc-400 mt-1">
        Cloud / DevOps Engineer
      </p>
    </div>
  </div>

  <p class="text-[15px] text-zinc-600 dark:text-zinc-400 leading-[1.75] max-w-[600px] mb-7">
    Building reliable, scalable infrastructure on AWS — bridging software
    engineering and cloud operations with a security-first mindset.
  </p>

  <!-- Contact: warm, inline, with thin separators -->
  <div class="flex flex-wrap items-center gap-x-3 gap-y-1.5 text-[14px] text-zinc-500 dark:text-zinc-500">
    <span>Ho Chi Minh City, Vietnam</span>
    <span class="text-zinc-300 dark:text-zinc-700" aria-hidden="true">•</span>
    <a href="mailto:huynhthientung.dev@gmail.com" class={linkClass}>
      huynhthientung.dev@gmail.com
    </a>
    <span class="text-zinc-300 dark:text-zinc-700" aria-hidden="true">•</span>
    <a
      href="https://www.linkedin.com/in/huynhthientung"
      target="_blank"
      rel="noopener noreferrer"
      class={linkClass}
    >
      LinkedIn
    </a>
    <span class="text-zinc-300 dark:text-zinc-700" aria-hidden="true">•</span>
    <a
      href="https://github.com/huynhthientung"
      target="_blank"
      rel="noopener noreferrer"
      class={linkClass}
    >
      GitHub
    </a>
  </div>
</section>
