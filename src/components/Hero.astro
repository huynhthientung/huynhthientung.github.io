---
const linkClass =
  'text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-slate-100 underline-offset-4 hover:underline transition-colors';
---

<section class="pt-16 pb-10">
  <h1
    class="text-[32px] sm:text-[34px] font-semibold tracking-tight text-slate-900 dark:text-slate-50 leading-[1.15] mb-2"
  >
    Huynh Thien Tung
  </h1>

  <p class="text-base text-slate-600 dark:text-slate-400 mb-6">
    Cloud / DevOps Engineer
  </p>

  <p class="text-[14px] text-slate-500 dark:text-slate-500 leading-[1.75] max-w-[560px] mb-8">
    Building reliable, scalable infrastructure on AWS — bridging software
    engineering and cloud operations with a security-first mindset.
  </p>

  <!-- Contact: muted, inline, with thin separators -->
  <div class="flex flex-wrap items-center gap-x-3 gap-y-1.5 text-[13px] text-slate-500 dark:text-slate-500">
    <span>Ho Chi Minh City, Vietnam</span>
    <span class="text-slate-300 dark:text-slate-700" aria-hidden="true">•</span>
    <a href="mailto:huynhthientung.dev@gmail.com" class={linkClass}>
      huynhthientung.dev@gmail.com
    </a>
    <span class="text-slate-300 dark:text-slate-700" aria-hidden="true">•</span>
    <a
      href="https://www.linkedin.com/in/huynhthientung/"
      target="_blank"
      rel="noopener noreferrer"
      class={linkClass}
    >
      LinkedIn
    </a>
    <span class="text-slate-300 dark:text-slate-700" aria-hidden="true">•</span>
    <a
      href="https://github.com/huynhthientung"
      target="_blank"
      rel="noopener noreferrer"
      class={linkClass}
    >
      GitHub
    </a>
  </div>
</section>
